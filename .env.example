# Nuncio configuration reference. Copy to .env and edit, or set these as real
# environment variables / container env. See docs/CONFIGURATION.md for the
# full write-up of each setting.
#
# Only ONE variable is required: NUNCIO_LLM_URL. Everything else has a safe,
# generic default (delivery defaults to stdout, all collector backends
# default to "null" / disabled).

# --- LLM (required) ---------------------------------------------------------

# Base URL of any OpenAI-compatible chat-completions endpoint: a local Ollama
# instance, a self-hosted gateway, or a cloud provider. REQUIRED, no default.
NUNCIO_LLM_URL=http://your-llm-gateway:11434/v1

# API key/bearer token for NUNCIO_LLM_URL, if it requires one. Default: empty.
# NUNCIO_LLM_KEY=<your-llm-api-key>
NUNCIO_LLM_KEY=

# Model name/alias to request from NUNCIO_LLM_URL. Default: "default".
NUNCIO_LLM_MODEL=your-model

# Per-attempt LLM call timeout, in seconds. Default: 10.0
NUNCIO_LLM_TIMEOUT_S=10.0

# Cap on tokens requested from the LLM per enrichment. Default: 400
NUNCIO_LLM_MAX_TOKENS=400

# Extra HTTP headers to send with every LLM request, as a JSON object.
# Default: {}
NUNCIO_LLM_HEADERS={}

# --- Knowledge plane (optional second, hosted LLM for non-sensitive alerts) -

# Route alerts matching NUNCIO_CONFIG's classification_table to a second,
# hosted LLM instead of the private one above. Default: false
NUNCIO_KNOWLEDGE_ENABLED=false

# Base URL for the knowledge-plane LLM. Required if the above is true.
NUNCIO_KNOWLEDGE_URL=

# API key for the knowledge-plane LLM. Default: empty.
# NUNCIO_KNOWLEDGE_KEY=<your-knowledge-plane-api-key>
NUNCIO_KNOWLEDGE_KEY=

# Model name/alias for the knowledge-plane LLM. Default: empty.
NUNCIO_KNOWLEDGE_MODEL=

# --- Assist plane (optional, out-of-band) -------------------------------------
#
# A SINGLE, optional call to a hosted LLM (e.g. Gemini/OpenAI/any OpenAI-
# compatible endpoint) made STRICTLY AFTER the primary alert has already been
# delivered -- never inside the 30s alert budget above. It runs on its own
# worker thread with its own separate timeout (NUNCIO_ASSIST_TIMEOUT_S), so a
# hung or slow assist call can never delay or affect the primary alert, which
# has already gone out by the time assist starts. It is NOT an agentic loop:
# one scrub, one call, one insight (or none).
#
# What may leave the process is gated by TWO independent flags on purpose --
# NUNCIO_ASSIST_DATA_POSTURE picks WHAT may leave, NUNCIO_ASSIST_CONFIRM_EXTERNAL_OK
# is a separate attestation that an operator actually intended that -- so a
# single typo'd flag can never leak more than intended:
#   generic       (default) -- only the alert's category + severity + this
#                  deployment's classification-table generic string leave the
#                  process. No alert text, no identifiers, nothing scrubbed
#                  from a specific incident -- ever.
#   scrubbed-real -- the alert's own (redacted) content -- headline, top
#                  evidence, and the private enrichment's first line -- is
#                  additionally run through a stricter scrubber
#                  (nuncio.redactor.scrub_for_assist_plane) that also strips
#                  emails/IPs/full-domains and known-shape usernames before
#                  it ever leaves the process. Requires
#                  NUNCIO_ASSIST_CONFIRM_EXTERNAL_OK=true or startup fails.
# Honest limitation: the scrubber only catches usernames in `user=`/
# `username=`/`login=`-shaped key-value pairs and `/home/<name>/` paths -- a
# name mentioned in free prose has no reliable generic pattern and will NOT
# be caught. Cover org-specific shapes via NUNCIO_REDACT_EXTRA, same mechanism
# as any other secret shape.
#
# Default: disabled.
NUNCIO_ASSIST_ENABLED=false

# Base URL of any OpenAI-compatible chat-completions endpoint. Required if
# the above is true.
NUNCIO_ASSIST_URL=

# API key/bearer token for NUNCIO_ASSIST_URL, if it requires one.
# NUNCIO_ASSIST_KEY=<your-assist-api-key>
NUNCIO_ASSIST_KEY=

# Model name/alias to request from NUNCIO_ASSIST_URL. Recommend a Flash-tier
# (fast) alias, not a Pro-tier one: a Pro-tier alias commonly returns 429 on
# a free-tier key (paying for billing removes the 429s, but also flips that
# provider's terms to no-training on your traffic -- a tradeoff worth making
# deliberately, not by accident). A Flash-tier alias measured ~19s average /
# ~32s worst-case round trip in practice, comfortably inside the 60s default
# assist timeout below.
NUNCIO_ASSIST_MODEL=

# generic (default) or scrubbed-real -- see the policy note above.
NUNCIO_ASSIST_DATA_POSTURE=generic

# Required (=true) if NUNCIO_ASSIST_DATA_POSTURE=scrubbed-real; ignored
# (need not be set) for the default "generic" posture. Default: false
NUNCIO_ASSIST_CONFIRM_EXTERNAL_OK=false

# Comma-separated subset of critical|warning|info|ok|unknown -- only alerts
# at one of these severities are ever deferred to the assist plane.
# Default: "critical"
NUNCIO_ASSIST_SEVERITIES=critical

# The assist plane's OWN post-delivery budget, in seconds -- entirely
# separate from NUNCIO_BUDGET_S above; the assist call never runs inside the
# 30s alert deadline. Default: 60.0
NUNCIO_ASSIST_TIMEOUT_S=60.0

# --- Delivery ----------------------------------------------------------------

# Comma-separated list of delivery adapters to fan out to. Choices: stdout,
# apprise, ntfy, telegram, slack, webhook, email. Default: "stdout"
NUNCIO_DELIVERY=stdout

# Apprise gateway notify URL (only used if "apprise" is in NUNCIO_DELIVERY).
NUNCIO_APPRISE_URL=http://apprise:8000/notify/your-key

# ntfy topic URL / topic / token (only used if "ntfy" is in NUNCIO_DELIVERY).
NUNCIO_NTFY_URL=https://ntfy.sh
NUNCIO_NTFY_TOPIC=
# NUNCIO_NTFY_TOKEN=<your-ntfy-access-token>
NUNCIO_NTFY_TOKEN=

# Telegram bot token + chat id (only used if "telegram" is in NUNCIO_DELIVERY).
# NUNCIO_TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
NUNCIO_TELEGRAM_BOT_TOKEN=
NUNCIO_TELEGRAM_CHAT_ID=

# Slack incoming webhook URL (only used if "slack" is in NUNCIO_DELIVERY).
# NUNCIO_SLACK_WEBHOOK_URL=<https://hooks.slack.com/services/...>
NUNCIO_SLACK_WEBHOOK_URL=

# Generic webhook URL, headers (JSON object), and an optional body template
# (only used if "webhook" is in NUNCIO_DELIVERY).
NUNCIO_WEBHOOK_URL=
NUNCIO_WEBHOOK_HEADERS={}
NUNCIO_WEBHOOK_TEMPLATE=

# Title used on delivered messages. Deprecated/unused as of v0.3.0 (titles are
# now built from each alert's headline); kept as a settable key but ignored.
# Default: "Nuncio alert"
NUNCIO_DELIVERY_TITLE=Nuncio alert

# Email delivery (only used if "email" is in NUNCIO_DELIVERY). Alternative: an
# Apprise `mailto://` URL via NUNCIO_APPRISE_URL needs no SMTP config here at
# all if you already run Apprise -- this direct adapter is for a bare install
# with no Apprise gateway in front of it.
# NUNCIO_EMAIL_SMTP_HOST=smtp.example.com
NUNCIO_EMAIL_SMTP_HOST=
NUNCIO_EMAIL_SMTP_PORT=587
# NUNCIO_EMAIL_USER=alerts@example.com
NUNCIO_EMAIL_USER=
# NUNCIO_EMAIL_PASSWORD=<your-smtp-password>
NUNCIO_EMAIL_PASSWORD=
# NUNCIO_EMAIL_FROM=alerts@example.com
NUNCIO_EMAIL_FROM=
# NUNCIO_EMAIL_TO=you@example.com,oncall@example.com
NUNCIO_EMAIL_TO=
# One of: starttls, ssl, none. Default: "starttls"
NUNCIO_EMAIL_TLS=starttls

# Per-adapter verbosity override (JSON object of adapter name -> "brief" |
# "full"), overlaying the built-in default (ntfy/telegram/apprise=brief;
# email/slack/webhook/stdout=full). Default: "{}"
NUNCIO_DELIVERY_VERBOSITY={}

# --- Fail-safe delivery mode --------------------------------------------------

# One of: enriched, bypass. Default: "enriched"
#   enriched - enriches via the LLM and falls back to the raw alert on any
#              failure or timeout (exactly one message, never lost).
#   bypass   - skips enrichment and delivers the raw alert as-is.
NUNCIO_MODE=enriched

# --- Server / storage ----------------------------------------------------------

# Directory for the SQLite idempotency/audit store. Default: "/data"
NUNCIO_DATA_DIR=/data

# HTTP listen port. Default: 8095
NUNCIO_PORT=8095

# HTTP bind address. Default: "0.0.0.0"
NUNCIO_BIND=0.0.0.0

# Shared secret required (as header X-Auth-Token) on /ingest* requests.
# Default: empty (no auth -- put Nuncio behind a reverse proxy / IP allowlist).
# NUNCIO_INGEST_TOKEN=<a-random-shared-secret>
NUNCIO_INGEST_TOKEN=

# --- Settings screen (GET/POST /settings, optional) ---------------------------

# Admin token required (as header X-Admin-Token) to make ANY change via the
# settings screen or POST /settings. GET /settings and GET /settings.json are
# always readable (secrets masked) with no token at all. Leaving this unset
# means the settings screen renders in permanent read-only mode -- POST
# /settings always 403s. There is no way to enable writes without this: it is
# itself env-only and can never be set/rotated through the API it gates.
# Default: empty (writes disabled).
# NUNCIO_ADMIN_TOKEN=<a-random-admin-secret>
NUNCIO_ADMIN_TOKEN=

# --- Ingest ----------------------------------------------------------------

# Source adapter used by the back-compat POST /ingest (no source in the URL)
# when the payload doesn't say which source it came from. Default: "generic"
NUNCIO_DEFAULT_SOURCE=generic

# Comma-separated list of extra Python modules to import at startup, each
# registering a custom source adapter via @nuncio.sources.register.
NUNCIO_EXTRA_SOURCES=

# --- Engine / concurrency -----------------------------------------------------

# Hard wall-clock budget per alert, in seconds, before the fail-safe path
# takes over. Default: 30.0
NUNCIO_BUDGET_S=30.0

# Number of alerts enriched concurrently. Default: 1
NUNCIO_CONCURRENCY=1

# Max alerts queued for enrichment before load-shedding. Default: 20
NUNCIO_QUEUE_MAX=20

# Days of alert history kept in the store before pruning. Default: 30
NUNCIO_RETENTION_DAYS=30

# --- Context gathering ---------------------------------------------------------

# Per-collector timeout when gathering extra context for an alert. Default: 5.0
NUNCIO_GATHER_TIMEOUT_S=5.0

# Hard cap on the assembled context bundle size, in bytes. Default: 16000
NUNCIO_BUNDLE_MAX_BYTES=16000

# Time window (seconds) used to correlate related alerts together. Default: 600
NUNCIO_CORRELATION_WINDOW_S=600

# --- Collector backends (all optional, default to a no-op null client) -------
#
# Every backend below is READ-ONLY (query/GET endpoints only), bounded by a
# timeout strictly under NUNCIO_GATHER_TIMEOUT_S, and degrades to "no context"
# on any error -- a misconfigured or unreachable backend never blocks or
# breaks alert enrichment.

# Log backend: "null" (default), "openobserve", or "loki".
NUNCIO_LOGS=null
# Base URL. For openobserve, include the org segment, e.g.
# http://your-log-store:5080/api/default -- the client appends /_search and
# names the stream (NUNCIO_LOGS_INDEX) in the query.
# For loki, the server root, e.g. http://your-log-store:3100.
NUNCIO_LOGS_URL=
# Username for HTTP Basic auth (used by openobserve service accounts). Leave
# empty to use NUNCIO_LOGS_TOKEN alone as a bearer token instead.
NUNCIO_LOGS_USER=
# NUNCIO_LOGS_TOKEN=<your-log-store-token>
NUNCIO_LOGS_TOKEN=
# Stream/index name to query. Used as the OpenObserve stream name; unused by
# the loki backend (which instead selects on a label, see docs/CONFIGURATION.md).
NUNCIO_LOGS_INDEX=

# Container backend: "null" (default) or "docker".
NUNCIO_CONTAINERS=null
# unix:///path/to/docker.sock or http(s)://host:port. A raw Docker/Podman
# socket is root-equivalent to anything that can reach it -- a read-only
# socket-proxy (GET-only) in front of it is strongly recommended over
# mounting the real socket directly. See docs/CONFIGURATION.md.
NUNCIO_DOCKER_HOST=unix:///var/run/docker.sock

# Metrics backend: "null" (default), "prometheus", or "checkmk".
NUNCIO_METRICS=null
# Base URL: Prometheus server root (e.g. http://your-metrics:9090), or the
# CheckMK REST API root (e.g. http://your-checkmk/site/check_mk/api/1.0).
NUNCIO_METRICS_URL=
# CheckMK automation user name (unused by the prometheus backend, which is
# typically unauthenticated or fronted by a reverse-proxy auth layer).
NUNCIO_METRICS_USER=
# CheckMK automation user secret.
# NUNCIO_METRICS_TOKEN=<your-checkmk-automation-secret>
NUNCIO_METRICS_TOKEN=

# --- Redaction / privacy ------------------------------------------------------

# Path to a JSON file of extra {"type", "regex"} redaction rules, applied on
# top of the built-in secret catalog. Default: empty (none).
NUNCIO_REDACT_EXTRA=

# NOTE: there is no NUNCIO_REDACT_EXTRA_RULES env var -- inline extra rules of
# the same shape can additionally be managed live via the settings screen
# (see docs/CONFIGURATION.md#settings-screen); they're stored in
# settings-overrides.json, not read from the environment, and are strictly
# additive on top of both the built-in catalog and any NUNCIO_REDACT_EXTRA rules.

# --- Misc ----------------------------------------------------------------------

# Log level: debug, info, warning, error. Default: "info"
NUNCIO_LOG_LEVEL=info

# Path to an optional JSON config file (a documented JSON subset of YAML) for
# settings not covered by NUNCIO_* env vars, e.g. the knowledge-plane
# classification table. Default: empty (none).
# See config.example.json for a ready-to-copy template (e.g. NUNCIO_CONFIG=/config/nuncio.json).
NUNCIO_CONFIG=
